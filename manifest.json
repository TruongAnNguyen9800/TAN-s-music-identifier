{
  "manifest_version": 3,
  "name": "Hello Extensions",
  "version": "1.0",
  "description": "Base Level Extension",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "TANMF-icon.png"
  },
  "background": {
    "service_worker": "background.js"
  },
    "permissions": ["activeTab", "tabs", "tabCapture"]
}
